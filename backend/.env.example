# ================================================
# SMART PEST DOCTOR - BACKEND ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in real values
# NEVER commit .env to version control!
# ================================================

# ── Server ────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Database (MySQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=smart_pest_doctor
DB_POOL_MAX=10
DB_POOL_MIN=2
# Alternative single URL (Railway / PlanetScale):
# DATABASE_URL=mysql://user:password@host:3306/smart_pest_doctor

# ── JWT ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_64_chars
JWT_EXPIRES_IN=7d

# ── AI Services ───────────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Roboflow (plant disease detection) — https://app.roboflow.com
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_MODEL_ID=plant-disease-detection-iefbi/1

# Google Vision API — https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=your_google_vision_api_key
# Path to Google service account JSON (for TTS)
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# Groq (LLM fallback) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-70b-versatile

# Hugging Face (vision fallback) — https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key
HF_MODEL_URL=https://api-inference.huggingface.co/models/linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification

# ── Cloud Storage ─────────────────────────────────
# Cloudinary — https://cloudinary.com/console
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Weather ───────────────────────────────────────
WEATHER_API_KEY=your_weather_api_key
WEATHER_CRON_ENABLED=false
WEATHER_CRON_SCHEDULE=0 */6 * * *

# ── SMS / OTP ─────────────────────────────────────
# DEVELOPMENT ONLY - disable in production!
DEV_MODE=true
DEV_OTP=123456

# MSG91 (India) — https://msg91.com/
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=SPDOCT

# Fast2SMS (India) — https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key

# Twilio (global) — https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid
TWILIO_API_KEY_SID=your_twilio_api_key_sid

# ── Firebase Admin (phone OTP) ────────────────────
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=your_client_email
# FIREBASE_PRIVATE_KEY=your_private_key

# ── Product Search ────────────────────────────────
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# ── Payments (optional) ───────────────────────────
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Push Notifications (optional) ────────────────
# ONESIGNAL_APP_ID=your_app_id
# ONESIGNAL_API_KEY=your_api_key

# ── Redis (optional) ──────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── File Upload ───────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ── Logging ───────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ── Feature Flags ─────────────────────────────────
ENABLE_EXPERT_VIDEO_CALLS=true
ENABLE_VOICE_NOTES=true
ENABLE_OFFLINE_SYNC=true
